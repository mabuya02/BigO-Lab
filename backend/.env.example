APP_NAME=Big O Playground API
APP_ENV=development
DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# ── PostgreSQL ──
DB_DRIVER=postgresql+psycopg2
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bigOlab
DB_USER=
DB_PASSWORD=

# Docker postgres container reads these (must match DB_* above)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=bigOlab

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=false

# ── Signing ──
SECRET_KEY=change-this-in-production

# ── Code Execution ──
EXECUTION_BACKEND=auto
EXECUTION_QUEUE_BACKEND=auto
EXECUTION_ALLOW_LOCAL_FALLBACK=true
EXECUTION_DOCKER_IMAGE=big-o-playground-python-sandbox:latest
EXECUTION_WORKSPACE_ROOT=/tmp/big-o-playground-runs
EXECUTION_DEFAULT_TIMEOUT_SECONDS=3
EXECUTION_MAX_TIMEOUT_SECONDS=5
EXECUTION_MEMORY_LIMIT_MB=128
EXECUTION_OUTPUT_LIMIT_BYTES=32768
EXECUTION_CPU_LIMIT=1.0

# ── Complexity Explanation ──
EXPLANATION_PROVIDER=heuristic
EXPLANATION_ALLOW_FALLBACK=true
OLLAMA_API_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_TIMEOUT_SECONDS=20
OLLAMA_TEMPERATURE=0.2

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000
